// === GOOGLE OAUTH IMPLEMENTATION ===

/**
 * Google OAuth Login Implementation
 * 
 * Firebase Reference: https://firebase.google.com/docs/auth/web/google-signin
 * 
 * Frontend Flow:
 * 1. User clicks "Sign in with Google" button
 * 2. Firebase shows Google sign-in popup/redirect
 * 3. User selects or logs into Google account
 * 4. Google returns authorization code
 * 5. Firebase exchanges code for ID token
 * 6. Get ID token dan kirim ke backend
 * 7. Backend validates token dengan Firebase Admin SDK
 * 8. Backend returns JWT token
 * 9. Frontend stores JWT dan auto-login
 * 
 * Contoh implementasi:
 */

/*
async function loginWithGoogle() {
  try {
    // Firebase Reference: Create Google Auth Provider
    // GoogleAuthProvider handles:
    // - OAuth 2.0 flow dengan Google
    // - Requesting scopes: email, profile
    // - Handling sign-in popup/redirect
    const provider = new GoogleAuthProvider()
    
    // Firebase Reference: Optional - add custom scopes
    // provider.addScope('profile')
    // provider.addScope('email')
    
    // Firebase Reference: Sign in with popup
    // Modal dialog akan muncul untuk user memilih akun Google
    // Alternative: signInWithRedirect() untuk mobile
    const result = await signInWithPopup(auth, provider)
    
    // Firebase Reference: Get Firebase User
    const user = result.user
    console.log('Google user:', user.uid, user.email)
    
    // Firebase Reference: Get ID token
    // ID token berisi informasi terverifikasi dari Google
    // Token valid selama 1 jam
    const idToken = await user.getIdToken()
    
    // Send ID token ke backend untuk validasi dan JWT generation
    const data = await authApi.loginWithGoogle(idToken)
    
    // Store JWT token dan user data
    persist(data.token, data.user)
    return data
    
  } catch (error) {
    if (error.code === 'auth/popup-closed-by-user') {
      throw new Error('Sign-in dibatalkan oleh user')
    } else if (error.code === 'auth/popup-blocked') {
      throw new Error('Pop-up diblock oleh browser')
    } else {
      throw new Error('Google sign-in gagal: ' + error.message)
    }
  }
}
*/

/**
 * Google OAuth Registration Implementation
