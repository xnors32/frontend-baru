 * Frontend Flow:
 * 1. User clicks "Sign up with Google" button
 * 2. Firebase shows Google sign-in popup
 * 3. User memilih atau login ke akun Google
 * 4. Frontend shows role selection dialog
 * 5. Get ID token dan kirim ke backend dengan role
 * 6. Backend validates token dengan Firebase Admin SDK
 * 7. Backend creates user di database
 * 8. Backend returns JWT token (auto-login)
 * 9. Frontend stores JWT dan redirect ke dashboard
 * 
 * Contoh implementasi:
 */

/*
async function registerWithGoogle(role: Role) {
  try {
    // Firebase Reference: Create Google Auth Provider
    const provider = new GoogleAuthProvider()
    
    // Firebase Reference: Sign in with popup
    const result = await signInWithPopup(auth, provider)
    
    // Firebase Reference: Get user info dari Google
